        "# Unzip the MovieLens dataset into the current working directory.\n",
        "# The zip file should be uploaded to the Colab session before running.\n",
        "import zipfile, os\n",
        "\n",
        "zip_path = 'ml-latest-small.zip'\n",
        "if os.path.exists(zip_path):\n",
        "    with zipfile.ZipFile(zip_path, 'r') as z:\n",
        "        z.extractall('.')\n",
        "    print(\"Dataset extracted successfully.\")\n",
        "else:\n",
        "    print(f\"WARNING: '{zip_path}' not found. Upload it to the Colab session first.\")\n"
      ],
      "id": "P3ls07NmTjjE"
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
