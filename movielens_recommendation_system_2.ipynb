        "# ── Build results dataframe ───────────────────────────────────────────────────\n",
        "results = []\n",
        "\n",
        "for k in [5, 10, 20]:\n",
        "    p_pop, r_pop, _, _ = evaluate_precision_recall(recommend_popularity, k=k)\n",
        "    ndcg_pop            = evaluate_ndcg(recommend_popularity, k=k)\n",
        "\n",
        "    p_cf,  r_cf,  _, _ = evaluate_precision_recall(recommend_item_based, k=k)\n",
        "    ndcg_cf             = evaluate_ndcg(recommend_item_based, k=k)\n",
        "\n",
        "    results.append(['Popularity', k, p_pop, r_pop, ndcg_pop])\n",
        "    results.append(['Item-CF',    k, p_cf,  r_cf,  ndcg_cf])\n",
        "\n",
        "results_df = pd.DataFrame(\n",
        "    results,\n",
        "    columns=['Model', 'K', 'Precision@K', 'Recall@K', 'NDCG@K']\n",
        ")\n",
        "\n",
        "print(\"Evaluation results:\")\n",
        "results_df\n"
      ],
      "id": "463C82VfTjjN"
