      ],
      "source": [
        "# ── Evaluate both models at K = 5, 10, 20 ────────────────────────────────────\n",
        "print(\"Running evaluation — this may take a minute...\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "for k in [5, 10, 20]:\n",
        "    p_pop, r_pop, hits_pop, n_pop = evaluate_precision_recall(recommend_popularity, k=k)\n",
        "    ndcg_pop                       = evaluate_ndcg(recommend_popularity, k=k)\n",
        "\n",
        "    p_cf,  r_cf,  hits_cf,  n_cf  = evaluate_precision_recall(recommend_item_based, k=k)\n",
        "    ndcg_cf                        = evaluate_ndcg(recommend_item_based, k=k)\n",
        "\n",
        "    print(f\"\\n  K = {k}\")\n",
        "    print(f\"  {'Model':<20} {'Precision@K':>12} {'Recall@K':>10} {'NDCG@K':>10}\")\n",
        "    print(f\"  {'-'*55}\")\n",
        "    print(f\"  {'Popularity-Based':<20} {p_pop:>12.4f} {r_pop:>10.4f} {ndcg_pop:>10.4f}\")\n",
        "    print(f\"  {'Item-Based CF':<20} {p_cf:>12.4f} {r_cf:>10.4f} {ndcg_cf:>10.4f}\")\n",
        "    imp = (r_cf - r_pop) / r_pop * 100 if r_pop > 0 else 0\n",
        "    print(f\"  CF Recall improvement: +{imp:.0f}%\")\n",
        "\n",
        "print(\"\\n\" + \"=\" * 60)\n"
      ],
