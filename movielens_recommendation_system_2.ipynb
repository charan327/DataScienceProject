        "# ── Figure 4.7: Recall@K ──────────────────────────────────────────────────────\n",
        "plot_metric(\n",
        "    cf_vals   = cf_r,\n",
        "    pop_vals  = pop_r,\n",
        "    metric_label = 'Recall@K',\n",
