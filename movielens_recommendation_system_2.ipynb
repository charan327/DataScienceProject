        "blbls   = ['1–20', '21–50', '51–100', '101–200',\n",
        "           '201–300', '301–500', '501–1000', '1000+']\n",
        "bvals   = pd.cut(ucounts, bins=bins, labels=blbls).value_counts().reindex(blbls)\n",
        "\n",
        "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 6.5))\n",
        "fig.suptitle('Distribution of Ratings per User (User Activity) — MovieLens 100K',\n",
        "             fontsize=13, fontweight='bold', color=DGREY, y=1.01)\n",
        "\n",
        "# ── Left panel: binned bar chart ──────────────────────────────────────────────\n",
        "bcolors = [LBLUE if i < 4 else BLUE for i in range(len(blbls))]\n",
        "bs = ax1.bar(blbls, bvals.values, color=bcolors,\n",
        "             edgecolor='white', linewidth=1.2, zorder=3)\n",
        "for b, v in zip(bs, bvals.values):\n",
        "    ax1.text(b.get_x() + b.get_width() / 2, b.get_height() + 3,\n",
        "             str(v), ha='center', va='bottom',\n",
        "             fontsize=9.5, fontweight='bold', color=DGREY)\n",
        "\n",
        "ax1.set_xlabel('Ratings Submitted per User', fontsize=11, fontweight='bold', labelpad=8)\n",
        "ax1.set_ylabel('Number of Users', fontsize=11, fontweight='bold', labelpad=8)\n",
        "ax1.set_title('User Activity — Binned Distribution',\n",
        "              fontsize=12, fontweight='bold', color=ACCENT)\n",
        "ax1.tick_params(axis='x', rotation=38)\n",
        "ax1.set_ylim(0, bvals.max() * 1.22)\n",
        "ax1.text(0.97, 0.97,\n",
        "         f'Total users: {ratings[\"userId\"].nunique():,}\\n'\n",
