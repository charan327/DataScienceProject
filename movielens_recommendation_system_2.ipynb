      "source": [
        "## 11. Evaluation Metric Plots (Figures 4.6, 4.7, 4.8)\n",
        "\n",
        "The three plots below are identical to Figures 4.6, 4.7, and 4.8 in the project report.\n",
        "Each figure shows annotated data-point values, a shaded region representing the CF\n",
        "performance advantage, and a two-headed arrow marking the percentage improvement at K=10.\n"
      ],
      "id": "Cmb8rde1TjjN"
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 618
        },
        "id": "8iSinA8PTjjQ",
        "outputId": "fc9931a4-a895-430c-dd79-4525e5451497"
      },
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "text/plain": [
              "<Figure size 1100x650 with 1 Axes>"
            ],
            "image/png": "\n"
          },
          "metadata": {}
        },
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Saved: figure_4_6_precision.png\n"
          ]
        }
      ],
      "source": [
        "# ── Shared metric-plot helper ─────────────────────────────────────────────────\n",
        "def plot_metric(cf_vals, pop_vals, metric_label, ylabel,\n",
        "                filename, note_text, imp_k10):\n",
        "    \"\"\"\n",
        "    Generate a publication-quality metric comparison plot.\n",
        "\n",
        "    Produces an annotated line plot showing Item-Based CF vs Popularity-Based\n",
        "    across K ∈ {5, 10, 20}, with shaded advantage region and improvement arrow.\n",
        "    Saves the figure as a PNG and shows it inline.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    cf_vals      : list  — CF metric values at K=5,10,20\n",
        "    pop_vals     : list  — Popularity metric values at K=5,10,20\n",
        "    metric_label : str   — e.g. 'Precision@K'\n",
        "    ylabel       : str   — y-axis label\n",
        "    filename     : str   — output PNG filename\n",
        "    note_text    : str   — multi-line annotation in the bottom-left info box\n",
        "    imp_k10      : int   — integer percentage improvement at K=10 (for arrow label)\n",
        "    \"\"\"\n",
        "    K_VALS = [5, 10, 20]\n",
        "\n",
        "    fig, ax = plt.subplots(figsize=(11, 6.5))\n",
        "    fig.patch.set_facecolor('white')\n",
        "    ax.set_facecolor(GREY)\n",
        "    ax.spines['left'].set_color('#BBBBBB')\n",
        "    ax.spines['bottom'].set_color('#BBBBBB')\n",
        "\n",
        "    # Smooth curves via linear interpolation\n",
        "    ke  = np.linspace(5, 20, 400)\n",
        "    cfi = np.interp(ke, K_VALS, cf_vals)\n",
        "    poi = np.interp(ke, K_VALS, pop_vals)\n",
        "\n",
        "    # Shaded CF advantage region\n",
        "    ax.fill_between(ke, cfi, poi, where=(cfi >= poi),\n",
        "                    alpha=0.16, color=BLUE, zorder=1)\n",
        "\n",
        "    # Model lines\n",
        "    ax.plot(ke, poi, color=RED,  lw=2.6, ls='--', zorder=4, label='Popularity-Based')\n",
        "    ax.plot(ke, cfi, color=BLUE, lw=3.0,           zorder=5, label='Item-Based CF')\n",
        "\n",
        "    # Data-point markers\n",
        "    ax.scatter(K_VALS, pop_vals, color=RED,  s=100, zorder=6,\n",
        "               edgecolors='white', linewidths=1.8)\n",
        "    ax.scatter(K_VALS, cf_vals,  color=BLUE, s=120, zorder=6,\n",
        "               edgecolors='white', linewidths=2.0)\n",
        "\n",
        "    # Annotate every data point with its exact value\n",
        "    for k, vc, vp in zip(K_VALS, cf_vals, pop_vals):\n",
        "        ax.annotate(f'{vc:.4f}', xy=(k, vc), xytext=(0, 13),\n",
        "                    textcoords='offset points', ha='center', fontsize=9.5,\n",
        "                    fontweight='bold', color=BLUE,\n",
        "                    bbox=dict(boxstyle='round,pad=0.28', fc='white',\n",
        "                              ec=BLUE, alpha=0.9, lw=1.2))\n",
        "        ax.annotate(f'{vp:.4f}', xy=(k, vp), xytext=(0, -20),\n",
        "                    textcoords='offset points', ha='center', fontsize=9.5,\n",
        "                    fontweight='bold', color=RED,\n",
        "                    bbox=dict(boxstyle='round,pad=0.28', fc='white',\n",
        "                              ec=RED, alpha=0.9, lw=1.2))\n",
        "\n",
        "    # Improvement arrow at K=10\n",
        "    i10 = K_VALS.index(10)\n",
        "    c10, p10 = cf_vals[i10], pop_vals[i10]\n",
        "    mid = (c10 + p10) / 2\n",
        "    ax.annotate('', xy=(10, c10 - 0.00008), xytext=(10, p10 + 0.00008),\n",
        "                arrowprops=dict(arrowstyle='<->',\n",
        "                                color='#444', lw=1.6, mutation_scale=16))\n",
        "    ax.text(10.28, mid, f'+{imp_k10}%\\nat K=10',\n",
        "            fontsize=10, color='#333', fontstyle='italic', va='center')\n",
        "\n",
        "    # Axes and labels\n",
        "    ax.set_xticks(K_VALS)\n",
        "    ax.set_xticklabels([f'K = {k}' for k in K_VALS], fontsize=12)\n",
        "    ax.tick_params(axis='y', labelsize=10.5)\n",
        "    ax.yaxis.set_major_formatter(FormatStrFormatter('%.4f'))\n",
        "    ax.set_xlabel('K  (Recommendation List Length)',\n",
        "                  fontsize=12, fontweight='bold', labelpad=10, color=DGREY)\n",
        "    ax.set_ylabel(ylabel, fontsize=11, fontweight='bold',\n",
        "                  labelpad=10, color=DGREY)\n",
        "    ax.set_title(\n",
        "        f'{metric_label} — Item-Based CF vs Popularity-Based Model\\n'\n",
        "        f'MovieLens 100K  |  610 Users  |  Leave-One-Out Temporal Evaluation',\n",
        "        fontsize=13, fontweight='bold', color=ACCENT\n",
        "    )\n",
        "\n",
        "    lgd = ax.legend(fontsize=11, framealpha=0.96,\n",
        "                    loc='upper right', edgecolor='#ccc')\n",
        "    lgd.get_frame().set_linewidth(1.3)\n",
        "\n",
        "    # Info box — metric formula and key findings\n",
        "    ax.text(0.01, 0.04, note_text, transform=ax.transAxes,\n",
        "            fontsize=9.2, va='bottom',\n",
        "            bbox=dict(boxstyle='round,pad=0.48', fc=LIGHT,\n",
        "                      ec='#90CAF9', alpha=0.96))\n",
        "\n",
        "    ax.text(0.5, 0.975,\n",
        "            '▲ Shaded region = CF performance advantage over Popularity-Based baseline',\n",
        "            transform=ax.transAxes, fontsize=8.8, ha='center', va='top',\n",
        "            color='#555', style='italic')\n",
        "\n",
        "    plt.tight_layout(pad=1.8)\n",
        "    plt.savefig(filename, dpi=200, bbox_inches='tight', facecolor='white')\n",
        "    plt.show()\n",
        "    print(f\"Saved: {filename}\")\n",
        "\n",
        "\n",
        "# ── Extract values from results_df ───────────────────────────────────────────\n",
        "K_VALS = [5, 10, 20]\n",
        "\n",
        "def get_vals(model, metric):\n",
        "    return [\n",
        "        results_df[(results_df['Model'] == model) &\n",
        "                   (results_df['K'] == k)][metric].values[0]\n",
        "        for k in K_VALS\n",
        "    ]\n",
        "\n",
        "cf_p  = get_vals('Item-CF',    'Precision@K')\n",
        "pop_p = get_vals('Popularity', 'Precision@K')\n",
        "cf_r  = get_vals('Item-CF',    'Recall@K')\n",
        "pop_r = get_vals('Popularity', 'Recall@K')\n",
        "cf_n  = get_vals('Item-CF',    'NDCG@K')\n",
        "pop_n = get_vals('Popularity', 'NDCG@K')\n",
        "\n",
        "# ── Figure 4.6: Precision@K ───────────────────────────────────────────────────\n",
        "plot_metric(\n",
        "    cf_vals   = cf_p,\n",
        "    pop_vals  = pop_p,\n",
        "    metric_label = 'Precision@K',\n",
        "    ylabel    = 'Precision@K  (proportion of top-K recommendations that are relevant)',\n",
        "    filename  = 'figure_4_6_precision.png',\n",
        "    note_text = (\n",
        "        'Precision@K = hits in top-K / K\\n'\n",
        "        'CF peaks at K=10: 0.0064 vs 0.0041 (+56%)\\n'\n",
        "        'Relevance threshold: user rating ≥ 3.5'\n",
        "    ),\n",
        "    imp_k10 = 56\n",
        ")\n"
      ],
      "id": "8iSinA8PTjjQ"
    },
