      "source": [
        "# ── Figure 4.5: Movie Similarity Heatmap ─────────────────────────────────────\n",
        "# Show cosine similarity for the 10 most-rated movies.\n",
        "# Values are computed from the full 610-user rating matrix.\n",
        "\n",
        "def clean_title_sim(mid):\n",
        "    \"\"\"Return a clean title for the similarity heatmap axes.\"\"\"\n",
        "    t = movies.set_index('movieId')['title'].get(mid, str(mid))\n",
        "    t = re.sub(r'\\s*\\(\\d{4}\\)', '', t)\n",
        "    t = re.sub(r'^The\\s+', '', t)\n",
        "    return t[:20] if len(t) > 20 else t\n",
        "\n",
        "top10 = ratings.groupby('movieId')['rating'].count().nlargest(10).index\n",
        "names = [clean_title_sim(m) for m in top10]\n",
        "sdf   = pd.DataFrame(\n",
        "    cosine_similarity(user_movie[top10].T),\n",
        "    index=names, columns=names\n",
        ")\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(12, 10))\n",
        "fig.patch.set_facecolor('white')\n",
        "ax.set_facecolor('white')\n",
        "\n",
        "sns.heatmap(\n",
        "    sdf, annot=True, fmt='.3f', cmap='Blues',\n",
        "    vmin=0.35, vmax=1.0,\n",
        "    linewidths=0.6, linecolor='#e0e8f0',\n",
        "    ax=ax,\n",
        "    annot_kws={'size': 10, 'color': '#111', 'fontweight': 'bold'},\n",
        "    cbar_kws={'label': 'Cosine Similarity Score', 'shrink': 0.82}\n",
        ")\n",
        "\n",
        "ax.set_title(\n",
        "    'Movie Similarity Matrix — Cosine Similarity\\n'\n",
        "    'Top 10 Most-Rated MovieLens 100K Films  '\n",
        "    '(computed from full 610-user rating matrix)',\n",
        "    fontsize=13, fontweight='bold', color=ACCENT\n",
        ")\n",
        "ax.set_xlabel('Movie', fontsize=11, fontweight='bold', labelpad=10)\n",
        "ax.set_ylabel('Movie', fontsize=11, fontweight='bold', labelpad=10)\n",
        "ax.tick_params(axis='x', labelsize=10, rotation=35)\n",
        "ax.tick_params(axis='y', labelsize=10, rotation=0)\n",
        "ax.text(\n",
        "    0.5, -0.18,\n",
        "    'Diagonal = 1.000 (each movie is perfectly similar to itself)  ·  '\n",
        "    'Values computed via sklearn cosine_similarity on the full user–movie matrix',\n",
        "    transform=ax.transAxes, fontsize=9, ha='center', color='#555', style='italic'\n",
        ")\n",
        "\n",
        "plt.tight_layout(pad=2.2)\n",
        "plt.savefig('figure_4_5_similarity_heatmap.png', dpi=200,\n",
        "            bbox_inches='tight', facecolor='white')\n",
        "plt.show()\n",
        "print(\"Figure 4.5 saved as figure_4_5_similarity_heatmap.png\")\n"
      ],
      "id": "PVicGVwzTjjK"
