      "source": [
        "# ── Figure 4.3: Movie Popularity Distribution (dual panel) ───────────────────\n",
        "mcounts = ratings.groupby('movieId')['rating'].count().sort_values(ascending=False)\n",
        "\n",
        "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 6.5))\n",
        "fig.suptitle('Distribution of Ratings per Movie (Movie Popularity) — MovieLens 100K',\n",
        "             fontsize=13, fontweight='bold', color=DGREY, y=1.01)\n",
        "\n",
        "# ── Left panel: histogram ─────────────────────────────────────────────────────\n",
        "ax1.hist(mcounts.values, bins=65, color=BLUE, edgecolor='white', lw=0.7, zorder=3)\n",
        "ax1.axvline(mcounts.median(), color=RED, lw=2.0, ls='--',\n",
        "            label=f'Median: {int(mcounts.median())} ratings')\n",
        "ax1.axvline(mcounts.mean(), color=ORANGE, lw=2.0, ls=':',\n",
        "            label=f'Mean: {mcounts.mean():.0f} ratings')\n",
        "ax1.set_xlabel('Ratings per Movie', fontsize=11, fontweight='bold', labelpad=8)\n",
        "ax1.set_ylabel('Number of Movies', fontsize=11, fontweight='bold', labelpad=8)\n",
        "ax1.set_title('Movie Popularity — Rating Count Distribution',\n",
        "              fontsize=12, fontweight='bold', color=ACCENT)\n",
        "ax1.legend(fontsize=9.5, framealpha=0.95, edgecolor='#ccc')\n",
        "ax1.yaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f'{int(x):,}'))\n",
        "ax1.text(0.97, 0.97,\n",
        "         f'Total movies: {mcounts.shape[0]:,}\\n'\n",
        "         f'Movies with 1 rating: {(mcounts == 1).sum():,}\\n'\n",
        "         f'Movies ≥ 100 ratings: {(mcounts >= 100).sum():,}\\n'\n",
