      "source": [
        "# ── Figure 4.4: User–Movie Interaction Matrix heatmap ────────────────────────\n",
        "# Show a representative subset: 20 most active users × 25 most popular movies.\n",
        "# This makes the sparsity pattern and rating values clearly visible.\n",
        "\n",
        "def clean_title(mid):\n",
        "    \"\"\"Return a short clean movie title (no year, no leading 'The').\"\"\"\n",
        "    t = movies.set_index('movieId')['title'].get(mid, str(mid))\n",
        "    t = re.sub(r'\\s*\\(\\d{4}\\)', '', t)\n",
        "    t = re.sub(r'^The\\s+', '', t)\n",
        "    return t[:16]\n",
        "\n",
        "top_users = ratings.groupby('userId')['rating'].count().nlargest(20).index\n",
        "top_mids  = ratings.groupby('movieId')['rating'].count().nlargest(25).index\n",
        "\n",
        "sub = ratings[ratings['userId'].isin(top_users) &\n",
        "              ratings['movieId'].isin(top_mids)]\n",
        "mat = sub.pivot_table(\n",
        "    index='userId', columns='movieId', values='rating'\n",
        ").reindex(index=top_users, columns=top_mids).fillna(0)\n",
        "\n",
        "col_lbl = [clean_title(m) for m in mat.columns]\n",
        "row_lbl = [f'User {u}' for u in mat.index]\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(15, 7.5))\n",
        "fig.patch.set_facecolor('white')\n",
        "\n",
        "# White background for unrated cells, YlOrRd for rated\n",
        "masked = np.ma.masked_where(mat.values == 0, mat.values)\n",
        "ax.imshow(np.ones_like(mat.values), cmap='Greys',\n",
        "          vmin=0, vmax=1, alpha=0.04, aspect='auto')\n",
        "im = ax.imshow(masked, cmap='YlOrRd', vmin=0.5, vmax=5,\n",
        "               aspect='auto', interpolation='nearest')\n",
        "\n",
        "# Fine grid lines between cells\n",
        "ax.set_xticks(np.arange(-0.5, mat.shape[1], 1), minor=True)\n",
        "ax.set_yticks(np.arange(-0.5, mat.shape[0], 1), minor=True)\n",
        "ax.grid(which='minor', color='#cccccc', linewidth=0.5)\n",
        "ax.tick_params(which='minor', length=0)\n",
        "\n",
        "ax.set_xticks(range(mat.shape[1]))\n",
        "ax.set_xticklabels(col_lbl, fontsize=8.5, rotation=42, ha='right')\n",
        "ax.set_yticks(range(mat.shape[0]))\n",
        "ax.set_yticklabels(row_lbl, fontsize=9.5)\n",
        "\n",
        "ax.set_xlabel('Movie Title', fontsize=12, fontweight='bold', labelpad=10)\n",
        "ax.set_ylabel('User ID', fontsize=12, fontweight='bold', labelpad=10)\n",
        "ax.set_title(\n",
        "    'User–Movie Interaction Matrix\\n'\n",
        "    '20 Most Active Users × 25 Most Popular Movies  '\n",
        "    '(coloured = rated, white = not rated)',\n",
        "    fontsize=13, fontweight='bold', color=ACCENT\n",
        ")\n",
        "\n",
        "cbar = fig.colorbar(im, ax=ax, fraction=0.018, pad=0.01)\n",
        "cbar.set_label('Rating Score', fontsize=10.5)\n",
        "cbar.set_ticks([1, 2, 3, 4, 5])\n",
        "\n",
        "rated    = (mat.values > 0).sum()\n",
        "total    = mat.size\n",
        "sparsity = 100 * (1 - rated / total)\n",
        "ax.text(0.005, 0.012,\n",
        "        f'Subset sparsity: {sparsity:.1f}%  |  '\n",
        "        f'Rated cells: {rated} / {total}  |  '\n",
        "        f'Full 610-user matrix sparsity: > 98%',\n",
        "        transform=ax.transAxes, fontsize=9, color='#444',\n",
        "        bbox=dict(boxstyle='round,pad=0.35', fc='#EEF4FF', ec='#90CAF9'))\n",
        "\n",
        "plt.tight_layout(pad=1.6)\n",
        "plt.savefig('figure_4_4_interaction_matrix.png', dpi=200,\n",
        "            bbox_inches='tight', facecolor='white')\n",
        "plt.show()\n",
        "print(\"Figure 4.4 saved as figure_4_4_interaction_matrix.png\")\n"
      ],
