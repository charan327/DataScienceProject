        "outputId": "8a564b5f-1b5f-4e7f-b020-1da11329bd11"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Dataset loaded and cleaned successfully.\n",
            "  Ratings : 100,836\n",
            "  Users   : 610\n",
            "  Movies  : 9,724\n",
            "  Sparsity: 0.9830  (98.30% of user-movie pairs are empty)\n",
            "  Rating scale: 0.5 – 5.0\n"
          ]
        }
      ],
      "source": [
        "def load_movielens(folder: str):\n",
        "    \"\"\"\n",
        "    Load the MovieLens dataset from a local folder.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    folder : str\n",
        "        Path to the folder containing ratings.csv, movies.csv, and tags.csv.\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    ratings : pd.DataFrame\n",
        "    movies  : pd.DataFrame\n",
        "    tags    : pd.DataFrame or None\n",
        "    \"\"\"\n",
        "    p = Path(folder).expanduser().resolve()\n",
        "    if not (p / 'ratings.csv').exists():\n",
        "        raise FileNotFoundError(\n",
        "            f\"ratings.csv not found in '{p}'. \"\n",
        "            \"Check that ml-latest-small.zip was uploaded and extracted.\"\n",
        "        )\n",
        "\n",
        "    ratings = pd.read_csv(p / 'ratings.csv')\n",
        "    movies  = pd.read_csv(p / 'movies.csv')\n",
        "    tags    = pd.read_csv(p / 'tags.csv') if (p / 'tags.csv').exists() else None\n",
        "\n",
        "    # Convert Unix timestamps to datetime for readability and sorting\n",
        "    ratings['timestamp'] = pd.to_datetime(ratings['timestamp'], unit='s')\n",
        "    if tags is not None and 'timestamp' in tags.columns:\n",
        "        tags['timestamp'] = pd.to_datetime(tags['timestamp'], unit='s')\n",
        "\n",
        "    # Drop any exact duplicate rows\n",
        "    ratings = ratings.drop_duplicates()\n",
        "    movies  = movies.drop_duplicates()\n",
        "\n",
        "    return ratings, movies, tags\n",
        "\n",
        "\n",
        "ratings, movies, tags = load_movielens('ml-latest-small')\n",
        "\n",
        "n_users   = ratings['userId'].nunique()\n",
        "n_movies  = ratings['movieId'].nunique()\n",
        "n_ratings = len(ratings)\n",
        "sparsity  = 1 - n_ratings / (n_users * n_movies)\n",
        "\n",
        "print(\"Dataset loaded and cleaned successfully.\")\n",
        "print(f\"  Ratings : {n_ratings:,}\")\n",
        "print(f\"  Users   : {n_users:,}\")\n",
        "print(f\"  Movies  : {n_movies:,}\")\n",
        "print(f\"  Sparsity: {sparsity:.4f}  ({sparsity*100:.2f}% of user-movie pairs are empty)\")\n",
        "print(f\"  Rating scale: {ratings['rating'].min()} – {ratings['rating'].max()}\")\n"
      ],
      "id": "Xngy65UWTjjE"
    },
