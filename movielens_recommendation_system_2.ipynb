              "summary": "{\n  \"name\": \"recommend_similar_movies(movie_id=780, top_n=10)\",\n  \"rows\": 10,\n  \"fields\": [\n    {\n      \"column\": \"movieId\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 425,\n        \"min\": 1,\n        \"max\": 1240,\n        \"num_unique_values\": 10,\n        \"samples\": [\n          32,\n          480,\n          260\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"similarity\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.042376261100871906,\n        \"min\": 0.5368179482990806,\n        \"max\": 0.677354131253643,\n        \"num_unique_values\": 10,\n        \"samples\": [\n          0.5595530673086192,\n          0.6384182218976583,\n          0.5844504204396774\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"title\",\n      \"properties\": {\n        \"dtype\": \"string\",\n        \"num_unique_values\": 10,\n        \"samples\": [\n          \"Twelve Monkeys (a.k.a. 12 Monkeys) (1995)\",\n          \"Jurassic Park (1993)\",\n          \"Star Wars: Episode IV - A New Hope (1977)\"\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"genres\",\n      \"properties\": {\n        \"dtype\": \"string\",\n        \"num_unique_values\": 9,\n        \"samples\": [\n          \"Mystery|Sci-Fi|Thriller\",\n          \"Action|Adventure|Sci-Fi|Thriller\",\n          \"Adventure|Animation|Children|Comedy|Fantasy\"\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"
            }
          },
          "metadata": {},
          "execution_count": 12
        }
      ],
      "source": [
        "# ── Example: explore similar movies for a given title ─────────────────────────\n",
        "def find_movie_ids(title_contains: str, n: int = 10):\n",
        "    \"\"\"Search for movies by partial title match.\"\"\"\n",
        "    mask = movies['title'].str.contains(title_contains, case=False, na=False)\n",
        "    return movies[mask][['movieId', 'title']].head(n)\n",
        "\n",
        "def recommend_similar_movies(movie_id: int, top_n: int = 10):\n",
        "    \"\"\"\n",
        "    Return the top_n most similar movies to a given movie using\n",
        "    the full cosine similarity matrix (exploratory use only —\n",
        "    does not use the train/test split).\n",
        "    \"\"\"\n",
        "    if movie_id not in movie_sim_df.columns:\n",
        "        return f\"movieId {movie_id} not found in similarity matrix.\"\n",
        "    sims = (\n",
        "        movie_sim_df[movie_id]\n",
        "        .sort_values(ascending=False)\n",
        "        .iloc[1:top_n + 1]\n",
        "        .reset_index()\n",
        "    )\n",
        "    sims.columns = ['movieId', 'similarity']\n",
        "    return sims.merge(movies[['movieId', 'title', 'genres']], on='movieId', how='left')\n",
        "\n",
        "# Demonstrate: find movies similar to Independence Day (movieId 780)\n",
        "print(\"Movies similar to Independence Day (movieId 780):\")\n",
        "recommend_similar_movies(movie_id=780, top_n=10)\n"
      ],
      "id": "MyVbv6NnTjjK"
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "gdzumzZFTjjK"
      },
      "source": [
        "## 7. Train-Test Split\n",
        "\n",
        "A **leave-one-out temporal split** is applied: for each user the single most recent rating\n",
        "(by timestamp) is withheld as the test item, while all earlier ratings form the training set.\n",
        "This ensures no future information leaks into training and reflects a realistic deployment\n",
        "scenario where the model must predict the next item a user will rate.\n"
      ],
      "id": "gdzumzZFTjjK"
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "-DUeUV9oTjjL",
        "outputId": "17d6ef2b-9d8a-4851-8afe-e53e3001b27d"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Train set: 100,226 interactions  (610 users)\n",
            "Test set:  610 interactions  (1 held-out item per user)\n"
          ]
        }
      ],
      "source": [
        "# ── Leave-one-out temporal train/test split ───────────────────────────────────\n",
        "ratings_sorted = ratings.sort_values(['userId', 'timestamp'])\n",
        "\n",
        "# The most recent rating per user becomes the test item\n",
        "test  = ratings_sorted.groupby('userId').tail(1)\n",
        "train = ratings_sorted.drop(test.index)\n",
        "\n",
        "print(f\"Train set: {train.shape[0]:,} interactions  \"\n",
        "      f\"({train['userId'].nunique()} users)\")\n",
        "print(f\"Test set:  {test.shape[0]:,} interactions  \"\n",
        "      f\"(1 held-out item per user)\")\n"
      ],
      "id": "-DUeUV9oTjjL"
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "CImtJUEUTjjL",
        "outputId": "5f7eb522-8e50-4676-f4c3-1cba797f0c0b"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Training matrix shape: (610, 9701)\n",
            "Item similarity matrix shape: (9701, 9701)\n",
            "Top 5 most-rated movies (training set): [356, 318, 296, 2571, 593]\n"
          ]
        }
      ],
      "source": [
        "# ── Build training matrix and training-based similarity ──────────────────────\n",
        "train_matrix = train.pivot_table(\n",
        "    index='userId',\n",
        "    columns='movieId',\n",
        "    values='rating'\n",
        ").fillna(0)\n",
        "\n",
        "print(f\"Training matrix shape: {train_matrix.shape}\")\n",
        "\n",
        "# Re-compute cosine similarity on training data only (no leakage)\n",
        "item_similarity_df = pd.DataFrame(\n",
        "    cosine_similarity(train_matrix.T),\n",
        "    index=train_matrix.columns,\n",
        "    columns=train_matrix.columns\n",
        ")\n",
        "\n",
        "# Popularity ranking from training set only\n",
        "popular_movies = (\n",
        "    train.groupby('movieId')['rating']\n",
        "    .count()\n",
        "    .sort_values(ascending=False)\n",
        "    .index\n",
        "    .tolist()\n",
        ")\n",
        "\n",
        "print(f\"Item similarity matrix shape: {item_similarity_df.shape}\")\n",
        "print(f\"Top 5 most-rated movies (training set): {popular_movies[:5]}\")\n"
      ],
      "id": "CImtJUEUTjjL"
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "fNe0tmfkTjjL"
      },
      "source": [
        "## 8. Recommender Functions"
      ],
      "id": "fNe0tmfkTjjL"
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "bqUOhDnSTjjL"
      },
      "outputs": [],
      "source": [
        "def recommend_popularity(user_id, k=10):\n",
        "    \"\"\"\n",
        "    Non-personalised popularity-based recommender.\n",
        "\n",
        "    Returns the top-K globally popular movies that the user has not\n",
        "    already rated in the training set. The same list is returned for\n",
        "    every user regardless of their individual rating history.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    user_id : int\n",
        "    k       : int  (default 10)\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    list of int (movieId)\n",
        "    \"\"\"\n",
        "    if user_id in train_matrix.index:\n",
        "        already_rated = set(\n",
        "            train_matrix.loc[user_id][train_matrix.loc[user_id] > 0].index\n",
        "        )\n",
        "    else:\n",
        "        already_rated = set()\n",
        "\n",
        "    recs = [m for m in popular_movies if m not in already_rated]\n",
        "    return recs[:k]\n",
        "\n",
        "\n",
        "def recommend_item_based(user_id, k=10):\n",
        "    \"\"\"\n",
        "    Item-based collaborative filtering recommender.\n",
        "\n",
        "    For each candidate movie not yet rated by the user, computes a\n",
        "    composite relevance score by aggregating cosine similarities between\n",
        "    the candidate and all movies in the user's training history, weighted\n",
        "    by the user's own ratings. Returns the top-K candidates.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    user_id : int\n",
        "    k       : int  (default 10)\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    list of int (movieId)\n",
        "    \"\"\"\n",
        "    if user_id not in train_matrix.index:\n",
        "        return []\n",
        "\n",
        "    user_ratings = train_matrix.loc[user_id]\n",
        "    rated_movies = user_ratings[user_ratings > 0]\n",
        "\n",
        "    if len(rated_movies) == 0:\n",
        "        return []\n",
        "\n",
        "    # Weighted sum of similarity scores\n",
        "    scores = (\n",
        "        item_similarity_df[rated_movies.index]\n",
        "        .mul(rated_movies.values, axis=1)\n",
        "        .sum(axis=1)\n",
        "    )\n",
        "\n",
        "    # Remove already-rated movies\n",
        "    scores = scores.drop(index=rated_movies.index, errors='ignore')\n",
        "    return scores.nlargest(k).index.tolist()\n"
      ],
      "id": "bqUOhDnSTjjL"
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "T71f1sk4TjjM"
      },
      "source": [
        "## 9. Evaluation\n",
        "\n",
        "Both models are evaluated using three standard ranking metrics at K ∈ {5, 10, 20}:\n",
        "\n",
        "- **Precision@K**: fraction of top-K recommendations that are relevant.\n",
        "- **Recall@K**: fraction of all relevant items retrieved in the top-K list.\n",
        "- **NDCG@K**: normalised discounted cumulative gain — rewards placing relevant items\n",
        "  nearer the top of the list via a logarithmic discount function.\n",
        "\n",
        "A held-out item is treated as **relevant** if the user's withheld rating ≥ 3.5, consistent\n",
        "with standard positive-feedback thresholds in the recommendation literature.\n"
      ],
      "id": "T71f1sk4TjjM"
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "hGXdd8hkTjjM"
      },
      "outputs": [],
      "source": [
        "def evaluate_precision_recall(model_func, k=10):\n",
        "    \"\"\"\n",
        "    Compute Precision@K and Recall@K for a given recommender function.\n",
        "\n",
        "    Uses leave-one-out evaluation: for each user in the test set, the model\n",
        "    generates top-K recommendations and checks whether the held-out item appears.\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    precision : float\n",
        "    recall    : float\n",
        "    hits      : int\n",
        "    total_users : int\n",
        "    \"\"\"\n",
        "    hits        = 0\n",
        "    total_users = 0\n",
        "\n",
        "    for _, row in test.iterrows():\n",
        "        user_id    = row['userId']\n",
        "        true_movie = row['movieId']\n",
        "\n",
        "        # Skip users whose held-out rating is below the relevance threshold\n",
        "        if row['rating'] < 3.5:\n",
        "            continue\n",
        "\n",
        "        recs = model_func(user_id, k=k)\n",
        "        if len(recs) == 0:\n",
        "            continue\n",
        "\n",
        "        total_users += 1\n",
        "        if true_movie in recs:\n",
        "            hits += 1\n",
        "\n",
        "    precision = hits / (total_users * k) if total_users > 0 else 0.0\n",
        "    recall    = hits / total_users        if total_users > 0 else 0.0\n",
        "    return precision, recall, hits, total_users\n",
        "\n",
        "\n",
        "def evaluate_ndcg(model_func, k=10):\n",
        "    \"\"\"\n",
        "    Compute NDCG@K for a given recommender function.\n",
        "\n",
        "    For each user the DCG is 1 / log2(rank + 1) if the held-out item\n",
        "    appears in the top-K list, and 0 otherwise. The ideal DCG (IDCG)\n",
        "    is 1.0 (relevant item ranked first), so NDCG = DCG / IDCG = DCG.\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    mean NDCG : float\n",
        "    \"\"\"\n",
        "    ndcg_scores = []\n",
        "\n",
        "    for _, row in test.iterrows():\n",
        "        user_id    = row['userId']\n",
        "        true_movie = row['movieId']\n",
        "\n",
        "        if row['rating'] < 3.5:\n",
        "            continue\n",
        "\n",
        "        recs = model_func(user_id, k=k)\n",
        "        if len(recs) == 0:\n",
        "            continue\n",
        "\n",
        "        if true_movie in recs:\n",
        "            rank = recs.index(true_movie) + 1      # 1-indexed\n",
        "            ndcg_scores.append(1.0 / math.log2(rank + 1))\n",
        "        else:\n",
        "            ndcg_scores.append(0.0)\n",
        "\n",
        "    return float(np.mean(ndcg_scores)) if ndcg_scores else 0.0\n"
      ],
      "id": "hGXdd8hkTjjM"
    },
