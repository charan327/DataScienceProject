      "source": [
        "# ── Build the full user–movie interaction matrix ──────────────────────────────\n",
        "user_movie = ratings.pivot_table(\n",
        "    index='userId',\n",
        "    columns='movieId',\n",
        "    values='rating',\n",
        "    aggfunc='mean'\n",
        ").fillna(0)\n",
        "\n",
        "print(f\"User–movie matrix shape: {user_movie.shape}\")\n",
        "print(f\"Sparsity: {(user_movie.values == 0).sum() / user_movie.size * 100:.2f}%\")\n",
        "user_movie.iloc[:5, :5]\n"
      ],
